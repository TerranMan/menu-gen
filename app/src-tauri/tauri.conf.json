{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Menu Gen",
  "version": "0.1.0",
  "identifier": "com.terranman.menu-gen",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Генератор меню",
        "width": 900,
        "height": 720,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "category": "Productivity",
    "shortDescription": "Семейный генератор меню",
    "longDescription": "Генератор семейного меню на неделю с картинками блюд",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
